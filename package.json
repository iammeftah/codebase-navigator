{
  "name": "codebase-navigator",
  "displayName": "Codebase Navigator",
  "description": "Navigate any codebase instantly",
  "version": "0.0.1",
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codebase-navigator",
          "title": "Codebase Navigator",
          "icon": "$(map)"
        }
      ]
    },
    "views": {
      "codebase-navigator": [
        {
          "type": "webview",
          "id": "codebaseNavigator.sidebar",
          "name": "Navigator"
        }
      ]
    },
    "commands": [
      {
        "command": "codebase-navigator.analyze",
        "title": "Analyze Workspace"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint": "^9.9.1",
    "typescript": "^5.4.5",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}